<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="mod/booking/bookingextension/agent/db" VERSION="2026051900" COMMENT="XMLDB file for bookingextension_agent"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_wbagent_ai_threads" COMMENT="AI agent conversation threads, one per user per booking context">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="cmid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Course-module id (booking instance)"/>
        <FIELD NAME="bookingid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Booking instance id"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="active" SEQUENCE="false" COMMENT="active | closed"/>
        <FIELD NAME="metadatajson" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Analytics metadata: intent categories, entities, state"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="useridcmid" UNIQUE="false" FIELDS="userid, cmid"/>
        <INDEX NAME="statusidx" UNIQUE="false" FIELDS="status"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_wbagent_ai_messages" COMMENT="Individual messages within an AI agent conversation thread">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="threadid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="role" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="user" SEQUENCE="false" COMMENT="user | assistant | system"/>
        <FIELD NAME="content" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Raw message text"/>
        <FIELD NAME="structuredjson" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Extracted intent, entities, validated draft command"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="threadid" TYPE="foreign" FIELDS="threadid" REFTABLE="local_wbagent_ai_threads" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="threadidx" UNIQUE="false" FIELDS="threadid"/>
        <INDEX NAME="useridthreadidx" UNIQUE="false" FIELDS="userid, threadid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_wbagent_ai_runs" COMMENT="AI agent execution runs tracking actions to be or already executed">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="threadid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="cmid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="pending" SEQUENCE="false" COMMENT="pending | queued | running | completed | failed"/>
        <FIELD NAME="idempotencykey" TYPE="char" LENGTH="64" NOTNULL="true" SEQUENCE="false" COMMENT="SHA256 hash for deduplication"/>
        <FIELD NAME="commandsjson" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Interpreter-validated execution commands"/>
        <FIELD NAME="resultsjson" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Execution results per action"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="threadid" TYPE="foreign" FIELDS="threadid" REFTABLE="local_wbagent_ai_threads" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="useridcmidx" UNIQUE="false" FIELDS="userid, cmid"/>
        <INDEX NAME="statusidx" UNIQUE="false" FIELDS="status"/>
        <INDEX NAME="idempotencyidx" UNIQUE="true" FIELDS="idempotencykey"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_wbagent_ai_llm_debug" COMMENT="Raw LLM request/response strings for booking AI debug mode">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="threadid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="cmid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="source" TYPE="char" LENGTH="100" NOTNULL="true" SEQUENCE="false" COMMENT="Call site identifier (orchestrator/feedback/followup)"/>
        <FIELD NAME="requesttext" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Exact prompt string sent to provider"/>
        <FIELD NAME="responsetext" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Exact raw provider response string"/>
        <FIELD NAME="success" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="1=provider success, 0=provider error/exception"/>
        <FIELD NAME="errormessage" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Failure detail when success=0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="threadid" TYPE="foreign" FIELDS="threadid" REFTABLE="local_wbagent_ai_threads" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="threadtimeidx" UNIQUE="false" FIELDS="threadid, timecreated"/>
        <INDEX NAME="cmidtimeidx" UNIQUE="false" FIELDS="cmid, timecreated"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
