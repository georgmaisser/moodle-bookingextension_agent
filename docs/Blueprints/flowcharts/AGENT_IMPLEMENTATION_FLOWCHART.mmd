%%{init: {"theme": "base", "themeVariables": {"fontSize": "12px"}}}%%
flowchart TD

    %% =========================================================
    %% ENTRY LAYER
    %% =========================================================
    subgraph ENTRY["External API Layer (classes/external/)"]
        ASM["ai_send_message::execute()\ncontextid · message · threadid"]
        ACR["ai_confirm_run::execute()\ncontextid · threadid · queue_item_id · allow_session"]
        APO["ai_poll_thread::execute()"]
        APREVIEW["ai_render_command_preview::execute()"]
    end

    %% =========================================================
    %% AUTH + STORE
    %% =========================================================
    subgraph AUTHZ["authorization_service"]
        AZ1["require_use_capability(userid, contextid)"]
        AZ2["require_valid_context(contextid)"]
        AZ3["is_agent_extension_installed()"]
    end

    subgraph CSTORE["conversation_store (DB-backed)"]
        CS1["get_or_create_thread(userid, contextid, bookingid)"]
        CS2["add_message(threadid, role, text, meta)"]
        CS3["get_recent_messages(threadid, limit)"]
        CS4["get_run(runid) / create_run()"]
        CS5["get_pending_intent(threadid)"]
        CS6["set_pending_intent(threadid, intent)"]
        CS7["get_thread_metadata_value(key)"]
        CS8["set_thread_metadata_value(key, value)"]
        CS9["clear_step_messages(threadid)"]
        CS10["run_exists_other_than(idem_key, runid)"]
        CS11["allow_confirmation_for_session(userid, contextid)\nscope: user + Moodle context"]
        CS12["is_confirmation_allowed_for_session(userid, contextid)"]
        CS13["consume_pending_intent(threadid, userid, contextid)"]
        CS14["set/get user_input_lang metadata\n(authoritative turn language)"]
    end

    %% =========================================================
    %% AGENT RUNTIME
    %% =========================================================
    subgraph RUNTIME["agent_runtime — Agent Loop Coordinator"]
        RUN["run(threadid, contextid, userid)\ncontext entry"]
        RUNLOOP["run_loop(threadid, contextid, userid, maxsteps=0)\nMAX_LOOP_STEPS = 6"]
        LOOP_INIT["agent_state::make(limit)\n+ catalog_state cached once per turn\n+ load user_input_lang (no language heuristics)\nor make_resumed() if _loop_resume exists"]
        LOOP_STEP["for step = 0..limit-1\nstate.currentstep = step+1\nclear_step_messages()"]
        RUNINT["run_internal(threadid, contextid, userid, observations, state)\n→ StepResult"]
        STEP_RESULT{"StepResult\ncontinue | stop | escalate"}
        OBS_ACCUM["observation_builder + result_payload_summarizer\nprivacy_anonymizer::anonymize_value_for_llm()\nstate.add_observation(observation)"]
        LF_CHECK["loop_finalizer::finalize_timeout_only()\n(safety-net only, no semantic routing)"]
        LF_STOP["Timeout / budget clarification"]
        BUDG_CHECK{"budget_guard_allows\n_next_llm_call(step, limit)?"}
        BUDGX["build_budget_exceeded_result()\nissue_codes: BUDGET_EXCEEDED"]
        LOOP_STOP["Loop stop:\nconfirmation_request / clarification\n/ planner_retry_exhausted / sufficient"]
        REFRESH["refresh_pending_queue_retry_state()\nqueue items: retry_waiting → ready if can_pickup_now()"]
        ENFORCE["enforce_final_response_contract(result, threadid)"]
        MPS["message_persistence_service\n::persist_assistant_message(threadid, result)"]
    end

    %% =========================================================
    %% ORCHESTRATOR
    %% =========================================================
    subgraph ORCH["orchestrator — Explicit Planner Contract"]
        ORC["process(threadid, contextid, userid, step_type, observations)\nstep_type: tool_call_parse | simple_retrieval\n  final_reasoning | final_synthesis"]
        PPB["prompt_policy_builder::build()\ninitial_system_prompt.md"]
        ACAT["planner_catalog_service\n::get_catalog_from_agent_state()\n→ explicit task_prompt_contracts only\n→ no task-name or field-name heuristics\n→ no re-embed during loop"]
        OR_LANG["language contract\nLLM + deterministic replies follow latest user message\n(no de/en token lists in routing)"]
        LLMSVC["llm_call_service::invoke(threadid, contextid, userid,\n  source, prompt, action_class)\naction: planner_decide | generate_agent_reply\n  generate_text | generate_embeddings"]
        INTERP["interpreter::interpret(rawresponse, contextid, userid, lastmsg)\nStage 1: parse() — JSON extraction\nStage 2: classify response_type (allow-list)\nStage 3: check_structure() per task\nStage 4: normalize (dates, IDs, __current_user__)"]
        RESP_TYPE{"parsed\nresponse_type"}
    end

    %% =========================================================
    %% DECISION SERVICE
    %% =========================================================
    subgraph DECIDSVC["agent_decision_service::process() — Deterministic Routing"]
        PROC_IN["process(result, threadid, contextid, userid,\n  outputlang, previewoptionid)"]
        D_PREVIEW{"core.is_preview\n_request trigger?"}
        D_PREVIEW_OUT["→ clarification with preview message"]
        D_CONF["confirmation_state_machine\nHas pending_intent?"]
        D_DUPL["Duplicate-title override\nDUPLICATE_TITLE_CONFIRM_REQUIRED\nDUPLICATE_TITLE_MULTI_CONFIRM_REQUIRED"]
        D_AMBIG["Ambiguity gate\nmissing/ambiguous entity resolution\n(e.g. 2x 'Billy')"]
        D_AMBIG_OUT["→ clarification / planner re-plan\n(no spawn for unresolved entities)"]
        D_MUT_GUARD["Lookup-safety mutation guard\n(no mutate during lookup-only context)"]
        D_ROUTE{"response_type"}
        D_READONLY["Read-only task_call →\nexecutor::execute_commands()\n→ execution_result"]
        D_MUTATE["Mutating task_call →\npreflight_pipeline v2\n(default requires confirmation)"]
        D_CONFIRM["confirmation_request →\nconfirmation_state_machine"]
        D_RETRY["planner_retry\nmax 2x per turn"]
        D_RETRY_EXH["planner_retry exhausted\n→ clarification"]
    end

    %% =========================================================
    %% PREFLIGHT PIPELINE
    %% =========================================================
    subgraph PREFLIGHT["Preflight Pipeline v2 (services/preflight_pipeline.php)"]
        direction TB
        PP_RUN["preflight_pipeline::run(next executable slice, threadid, contextid, userid)\n→ returns preflight_result_v2 only"]

        subgraph L1["Layer 1 — Schema + Version Validation"]
            PF_L1["preflight_schema_validator::validate(command)\n+ command_schema.json\n+ preflight_version_validator::validate_version()"]
        end
        L1_OK{"schema + version\nvalid?"}
        L1_FAIL["hard_block\nblockinglayer: schema\nISSUE: SCHEMA_ERROR\n/ SCHEMA_UNAVAILABLE"]

        subgraph L2["Layer 2 — Domain Prepare"]
            PF_L2P["task::preflight(input, contextid, userid)\n— DB-dependent prepare + validation\n— late-bound dependency outputs allowed\n→ preflight_result_v2"]
            PF_L2D["preflight_domain_check_runner::run(\n  issue_codes, startmicrotime)\nhard block: PERMISSION_ERROR, VALIDATION_ERROR, MISSING_*\nsoft block: DOMAIN_CONFLICT, DUPLICATE_TITLE_*"]
        end
        L2_STATUS{"preflight\nstatus?"}

        subgraph L3["Layer 3 — Execution Gate Hint"]
            PF_L3["preflight_execution_gate::evaluate(\n  error_class, retry_count, issue_codes)\nbase: 500ms · jitter: 200ms\nmax_retries: 4 · max_backoff: 4000ms"]
        end

        PRV2["preflight_result_v2 (single DTO)\nstatus: pass | soft_block | hard_block | retry_hint\nblockinglayer: schema | domain | execution_gate\nretryafterms · retrycount · durationms\npreparedinput · issues · execution_guard_token"]
        PAL["preflight_audit_logger::append()\n(if preflight_audit_enabled)\n→ conversation_store thread metadata"]
    end

    %% =========================================================
    %% QUEUE MANAGER
    %% =========================================================
    subgraph QUEUE["Shadow Queue (queue/queue_manager.php)"]
        Q_ENQUEUE["enqueue_command(\n  threadid, runid, stepid, contextid,\n  command, mutability, status, depends_on)\n→ validate_depends_on_is_dag()\n→ build_input_signature()\n→ idempotency: return existing if same signature + non-terminal"]
        Q_DAG{"DAG\nvalid?"}
        Q_DAGFAIL["status: failed\nISSUE: DEPENDENCY_CYCLE"]
        Q_DEPCHECK{"dependencies\n_succeeded()?"}
        Q_BIND["bind dependency artifacts\nproducer outputs → child input\nthen late preflight"]
        Q_SKIP["status: skipped — terminal"]
        Q_RUNNING["try_mark_running(threadid, queueitemid)\n[Atomic: SELECT FOR UPDATE + check + set\nmax 1 running per thread]"]
        Q_CANPICK["can_pickup_now(item, now, items)\n→ next_retry_at ≤ now\n→ blocked_expires_at not expired"]
        Q_READY["status: ready"]
        Q_BLOCKED["status: blocked_confirmation\nblocked_expires_at = now + TTL(900s)"]
        Q_RETRY["status: retry_waiting\nnext_retry_at = now + retry_after_ms\nbackoff_ms persisted"]
        Q_FAIL_TTL["fail_expired_blocked_items(threadid)\nstatus: failed (BLOCKED_TIMEOUT)"]
        Q_UPDST["update_status(threadid, queue_item_id,\n  status, issue_codes, error_class, msg)"]
        Q_SPAWN["spawn_commands[]\nplanned child commands with depends_on\n+ artifact reference bindings"]
        OB["observation_builder::build_observation(queue_items)\n→ compact queue observation"]
    end

    %% =========================================================
    %% EXECUTOR
    %% =========================================================
    subgraph EXEC["Execution Layer (executor.php)"]
        EXC["executor::execute_commands(\n  commands, contextid, userid,\n  idempotency_key, runid)"]
        EXC_IDEM["run_exists_other_than(idem_key, runid)\n→ status: skipped (already executed)"]
        EXC_EVAL["task_executability_evaluator\n::evaluate_task(taskname, userid, contextid)\ndeny reasons:\n  not_registered · inactive\n  missing_capability · context_invalid\n  runtime_disabled"]
        EXC_GUARD["execution_guard::verify(\n  prepared_input, execution_guard_token,\n  contextid, userid)\nno second full preflight"]
        EXC_GUARD_OK{"guard\npass?"}
        EXC_RUN["task::execute(prepared_input, contextid, userid)\n→ result payload"]
        EXC_SUCC["status: succeeded\n→ result / produced_outputs / follow-up suggestions\n→ spawn_commands[]"]
        EXC_TRANSIENT["transient error\n→ retry_waiting\nbackoff + jitter"]
        EXC_SPAWN["spawn_handler\nregister child commands in same queue/run"]
        EXC_DOMAIN["domain error\n→ failed + observation with error_detail"]
    end

    %% =========================================================
    %% TASK LAYER
    %% =========================================================
    subgraph TASKS["Task Layer"]
        TR["task_registry\nregister(provider)\nget_task(name)\nis_read_only_task()\nis_task_active()\nget_task_contract()\nget_all_schemas()\nget_all_prompt_contracts()\nget_prompt_contracts_for_context()"]
        TRFAC["task_registry_factory\n→ wires all task_provider_interface\n  implementations (auto-discovery)\n→ third-party onboarding: provider only, no framework edits"]
        TI["task_interface\nget_name() · get_schema()\nget_prompt_contract()\ncheck_structure(input)\npreflight(input,contextid,userid): preflight_result_v2\nexecute(prepared_input,contextid,userid): array\nis_read_only(): bool"]
        TPC["task_prompt_contract DTO\nintent · anchors · minimal_input · example_input\nnamespace · version · capabilities · context scopes"]
        BT["base_task (abstract)\ncheck_structure() → pass\npreflight() → pass (override for DB checks)\nexecute() → abstract"]
        BTASK["booking_task_base\n→ focused task set only\nnew tasks must declare explicit prompt contract"]
        CTASK["core_task_base\n→ focused task set only\nnew tasks must declare explicit prompt contract"]
        TCV["task_contract_validator\n::build_task_metadata(task, component)\nnamespace · version · capabilities · active flag\n+ multi-gate executability checks"]
    end

    %% =========================================================
    %% SUPPORT SERVICES
    %% =========================================================
    subgraph SUPPORT["Support Services"]
        ANON["privacy_anonymizer\nanonymize_value_for_llm()\ndeanonymize_for_display()"]
        EMBS["embeddings_retrieval_service\nused for catalog build, not per-loop recovery"]
        LANG["language_policy_service\nsource priority: latest user message\n→ model-declared user_lang\n→ technical fallback\nformats all framework-generated replies"]
        MTRIG["message_trigger_registry\ncore trigger allow-list\nnormalize_used_triggers()\nserver derives core.is_lookup_request\n(no trigger→task routing)"]
        AIER["ai_error_classifier\n→ provider_timeout · transient_io\n· auth_failed · quota_exceeded"]
        ISCP["booking_issue_code_provider\nimplements issue_code_provider_interface\nget_duplicate_confirmation_issue_codes()\nget_token_subscription_issue_codes()\nget_prevalidation_confirmable_issue_codes()"]
        BIRS["booking_issue_code_resolver\n(booking/booking_task_support.php)"]
    end

    %% =========================================================
    %% TERMINAL STATES
    %% =========================================================
    subgraph OUTCOMES["Observation Builder Outputs → Loop Decision"]
        OB_OUT["observation_builder::build_observation()\n+ result_payload_summarizer::for_observation()\n→ compact observation string"]
        GOAL_CHECK{"Goal\nreached?"}
        REPLAN["Re-plan: run_internal() next step\n(simple_retrieval prompt)\n→ LLM receives observations as context\ncatalog_state reused from agent_state"]
        FINAL_SYNTH["Final Synthesis\norchestrator::process()\nstep_type: final_synthesis\n→ generate_agent_reply action"]
        FINAL_OUT["succeeded\nFinal polished answer to user"]
        FAIL_OUT["failed — terminal\n(hard_block / budget_exceeded\n/ retry_exhausted / dep_cycle)"]
    end

    %% =========================================================
    %% ========== CONNECTIONS =================================
    %% =========================================================

    %% Entry → Auth → Store → Runtime
    ASM -->|"1. require_sesskey()"| AZ1
    ASM -->|"2. validate_parameters()"| AZ2
    ASM -->|"3. add_message(user)"| CS2
    ASM -->|"4. run_loop()"| RUNLOOP
    ASM -->|"response autoconfirm?"| CS12
    ACR -->|"allow_session=true"| CS11
    ACR -->|"consume pending intent"| CS13
    CS13 -->|"queue item resolved"| Q_READY

    AZ1 --> CS1
    CS1 --> RUNLOOP

    %% Runtime loop setup
    RUNLOOP --> LOOP_INIT
    LOOP_INIT --> CS7
    LOOP_INIT --> CS14
    LOOP_INIT --> LOOP_STEP
    LOOP_STEP --> CS9
    LOOP_STEP --> RUNINT

    %% run_internal → orchestrator → LLM → interpreter
    RUNINT --> ORC
    ORC --> PPB
    ORC --> ACAT
    ORC --> OR_LANG
    ACAT --> TR
    ACAT --> EMBS
    OR_LANG --> LANG
    ORC --> LLMSVC
    LLMSVC -->|raw LLM output| INTERP
    INTERP --> RESP_TYPE

    %% interpreter output → decision service
    RESP_TYPE --> PROC_IN
    PROC_IN --> D_PREVIEW
    D_PREVIEW -->|yes| D_PREVIEW_OUT
    D_PREVIEW -->|no| D_CONF
    D_CONF --> D_DUPL
    D_DUPL --> D_AMBIG
    D_AMBIG -->|resolved| D_MUT_GUARD
    D_AMBIG -->|ambiguous/missing| D_AMBIG_OUT
    D_AMBIG_OUT --> LOOP_STOP
    D_MUT_GUARD --> D_ROUTE

    D_ROUTE -->|task_call readonly| D_READONLY
    D_ROUTE -->|task_call mutating| D_MUTATE
    D_ROUTE -->|confirmation_request| D_CONFIRM
    D_ROUTE -->|planner_retry| D_RETRY
    D_ROUTE -->|clarification / sufficient| LOOP_STOP
    D_ROUTE -->|unknown / invalid| D_RETRY

    D_RETRY -->|"retry <= 2"| LOOP_STEP
    D_RETRY -->|"retry exhausted"| D_RETRY_EXH
    D_RETRY_EXH --> LOOP_STOP

    %% Preflight pipeline
    D_MUTATE --> PP_RUN
    D_CONFIRM --> PP_RUN
    PP_RUN --> PF_L1
    PF_L1 --> L1_OK
    L1_OK -->|no| L1_FAIL
    L1_OK -->|yes| PF_L2P
    PF_L2P --> PF_L2D
    PF_L2D --> L2_STATUS

    L2_STATUS -->|hard_block| PRV2
    L2_STATUS -->|soft_block| PRV2
    L2_STATUS -->|retry_hint| PF_L3
    L2_STATUS -->|pass| PRV2
    PF_L3 --> PRV2
    PRV2 --> PAL
    PAL -->|"append() to thread metadata"| CS8

    %% Preflight result → Queue
    PRV2 -->|"pass + session allow => ready"| Q_ENQUEUE
    PRV2 -->|"pass + no session allow => confirmation required"| Q_BLOCKED
    PRV2 -->|"soft_block: confirmation required"| Q_BLOCKED
    PRV2 -->|"retry_hint"| Q_RETRY
    L1_FAIL -->|"hard_block: terminal"| FAIL_OUT
    PRV2 -->|"hard_block: terminal"| FAIL_OUT

    Q_ENQUEUE --> Q_DAG
    Q_DAG -->|cycle| Q_DAGFAIL
    Q_DAGFAIL --> FAIL_OUT
    Q_DAG -->|valid| Q_DEPCHECK
    Q_DEPCHECK -->|deps failed| Q_SKIP
    Q_SKIP --> FAIL_OUT
    Q_DEPCHECK -->|deps ok + prepared| Q_RUNNING
    Q_DEPCHECK -->|deps ok + needs binding| Q_BIND
    Q_BIND --> PP_RUN
    Q_RUNNING -->|slot occupied| Q_READY
    Q_READY -->|"try_pickup_now"| Q_RUNNING
    Q_READY -.->|"next run_loop() turn"| RUNLOOP
    Q_RUNNING -->|slot free| EXC

    %% Blocked confirmation TTL
    Q_BLOCKED -->|"TTL check: fail_expired_blocked_items()"| Q_FAIL_TTL
    Q_FAIL_TTL --> FAIL_OUT
    Q_BLOCKED -->|"user confirms via ai_confirm_run"| CS13
    CS13 -->|"update_status(ready)"| Q_READY
    Q_RETRY -->|"retry window elapsed"| Q_CANPICK
    Q_CANPICK -->|"can_pickup_now() = true"| EXC

    %% Read-only → executor
    D_READONLY --> EXC

    %% Executor flow
    EXC --> EXC_IDEM
    EXC_IDEM -->|"already executed → skipped"| FAIL_OUT
    EXC_IDEM -->|"first run"| EXC_EVAL
    EXC_EVAL --> TCV
    TCV -->|allow| EXC_GUARD
    EXC_GUARD --> EXC_GUARD_OK
    EXC_GUARD_OK -->|"pass"| EXC_RUN
    EXC_GUARD_OK -->|"fail"| FAIL_OUT
    TCV -->|deny| FAIL_OUT
    EXC_RUN --> EXC_SUCC
    EXC_RUN --> EXC_TRANSIENT
    EXC_RUN --> EXC_DOMAIN
    EXC_SUCC --> EXC_SPAWN
    EXC_SPAWN -->|"spawn_commands[] + depends_on"| Q_SPAWN
    Q_SPAWN -->|"enqueue planned child"| Q_ENQUEUE
    EXC_TRANSIENT -->|"retry count < max_retries"| Q_RETRY
    EXC_TRANSIENT -->|"max retries exceeded"| FAIL_OUT
    EXC_DOMAIN --> FAIL_OUT

    %% Outcomes → Observation Builder
    EXC_SUCC --> OB_OUT
    FAIL_OUT --> OB_OUT
    D_PREVIEW_OUT --> OB_OUT

    OB_OUT --> GOAL_CHECK
    GOAL_CHECK -->|"no, loop continues"| REPLAN
    GOAL_CHECK -->|"yes"| FINAL_SYNTH
    REPLAN -->|"observations → agent_state"| OBS_ACCUM
    OBS_ACCUM --> STEP_RESULT

    STEP_RESULT -->|"continue"| LF_CHECK
    STEP_RESULT -->|"stop"| LOOP_STOP
    STEP_RESULT -->|"escalate"| LOOP_STOP

    LF_CHECK -->|"rare timeout finalize"| LF_STOP
    LF_CHECK -->|"continue"| BUDG_CHECK
    BUDG_CHECK -->|"ok (step+1 < limit)"| LOOP_STEP
    BUDG_CHECK -->|"exhausted"| BUDGX

    %% Final steps
    LF_STOP --> REFRESH
    LOOP_STOP --> REFRESH
    BUDGX --> REFRESH
    FINAL_SYNTH --> FINAL_OUT
    FINAL_OUT --> REFRESH
    REFRESH --> ENFORCE
    ENFORCE --> MPS
    MPS -->|"add_message(assistant)"| CS2

    %% Task layer wiring
    TRFAC --> TR
    TR --> TI
    TI --> TPC
    TR --> BT
    BT --> BTASK
    BT --> CTASK
    TCV --> TR
    EXC_EVAL --> TR

    %% Support services
    INTERP -->|"slot_booking_normalizer"| INTERP
    INTERP -->|"normalize used_triggers"| MTRIG
    MTRIG -.->|"core trigger signals"| PROC_IN
    OB_OUT --> ANON
    ANON --> OBS_ACCUM
    AIER --> LLMSVC
    ISCP -.-> D_DUPL
    ISCP -.-> D_MUTATE

    %% =========================================================
    %% LEGEND
    %% =========================================================
    subgraph LEGEND["Legend"]
        direction TB
        LG_DB["DB rollout policy\nnew schema via install.xml only\nno migration / no upgrade.php"]
        LG_CTX["Context authority\nRuntime uses Moodle contextid\nas the scope key"]
        LG_AUTO["Auto-confirm\nconfirmation_request + session allowlist\nkeyed by user + contextid\n→ ai_confirm_run without manual click"]
        LG_MANUAL["Manual confirm\nblocked_confirmation\n→ user confirms via ai_confirm_run"]
        LG_LANG["Language fidelity\nreply language follows latest user input\n(no language-specific routing heuristics)"]
        LG_3P["Third-party onboarding\nprovider + task contract only\nno framework rewiring"]
        LG_PLAN["Planner-first for ambiguity\nentity resolution and branching via planner\n(clarify instead of silent auto-pick)"]
        LG_SPAWN_RULE["Spawn-only for deterministic follow-ups\nrequires bound outputs + valid late preflight"]
        LG_CAP["Task release gates\nruntime + active + context + capability"]
        LG_RETRY["Retry lifecycle\nplanner_retry / retry_waiting\n→ can_pickup_now() → execute"]
        LG_COMPLEX["Complex workflow capable\nspawn/dependency chains, artifact refs, late preflight\nacross domains"]
        LG_TERMINAL["Terminal outcomes\nfailed / skipped / budget_exceeded / success"]
        LG_DET["Deterministic routing only\nno recovery_enrichment fallback"]
    end

